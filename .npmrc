# Homebrew PNPM Enforcement Configuration
# ====================================
# This configuration ensures that only the globally installed Homebrew PNPM is used
# and prevents any conflicting local PNPM installations.

# Engine and Package Manager Enforcement
engine-strict=true
package-manager-strict=true

# Homebrew PNPM Integration
global-bin-dir=/opt/homebrew/bin
# use-node-version=system  # Commented out - system Node.js version will be used automatically

# Dependency Management
auto-install-peers=true
shamefully-hoist=false
strict-peer-dependencies=false
node-linker=isolated

# Workspace Configuration
prefer-workspace-packages=true
save-workspace-protocol=rolling

# Resolution Strategy
resolution-mode=highest

# Performance and Caching
# (Uses system defaults optimized for Homebrew installation)

# Security
# Prevent installation of packages with known vulnerabilities
audit-level=moderate

# Logging
loglevel=info

# Registry Configuration
# Uses default npm registry with Homebrew PNPM optimizations
