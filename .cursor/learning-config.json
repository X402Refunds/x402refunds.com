{
  "learningEnabled": true,
  "correctionThreshold": 2,
  "autoUpdateRules": true,
  
  "watchPatterns": {
    "corrections": [
      "stop doing X",
      "I told you before",
      "don't do that again",
      "never",
      "always"
    ],
    "antiPatterns": [
      "don't create",
      "stop generating",
      "never add",
      "stop doing"
    ]
  },
  
  "ruleUpdatePolicy": {
    "autoMerge": true,
    "requireApproval": false,
    "notifyUser": true
  },
  
  "duplicationPolicy": {
    "autoDedup": true,
    "similarityThreshold": 0.7,
    "preferCoreRules": true
  },
  
  "compressionTargets": {
    "maxRuleSize": 200,
    "maxExamples": 3,
    "removeVerbosity": true
  },
  
  "contextBudget": {
    "maxTokens": 4000,
    "maxRulesPerChat": 3,
    "prioritizeRecent": true
  }
}
