pnpm type-check    # Verify component types
pnpm build         # Ensure pages compile
```

### Backend Changes (convex/)
```bash
# MANDATORY for all backend changes
pnpm lint          # Check Convex functions
pnpm type-check    # Verify schema types
pnpm build         # Validate production build
pnpm deploy        # Deploy to test in production
pnpm test:run      # Run API tests
```

### Configuration Changes (package.json, tsconfig.json)
```bash
# EXTRA MANDATORY for config changes
rm pnpm-lock.yaml
pnpm install
pnpm install --frozen-lockfile  # Verify CI will work
pnpm lint
pnpm type-check
pnpm build
pnpm test:run      # Ensure nothing broke
```

### CSS/Style Changes (globals.css, components)
```bash
# MANDATORY for style changes
pnpm lint          # Check CSS syntax
pnpm build         # Ensure styles compile
# Visual verification in browser
pnpm dev           # Check in development
```

