    throw new Error("Premium agents require minimum stake of 10000");
  }
```

### 5. Function-Based Sub-Agents Instead of Spawned Processes

**Traditional:** Spawn separate agent processes for specialized tasks
**Consulate:** Specialized logic as pure Convex functions

```typescript
// Judges are functions, not separate agent processes
export const submitVote = mutation({
  handler: async (ctx, args) => {
    // Simple deterministic logic - no external LLM calls needed
    const vote = { 
      judgeId: args.judgeId, 
      code: args.code, 
      reasons: args.reasons 
    };
    
    // Update shared state directly
    const updatedVotes = panel.votes ? [...panel.votes, vote] : [vote];
    await ctx.db.patch(args.panelId, { votes: updatedVotes });
  }
});
```

### 6. Sponsorship Hierarchies Instead of Parent-Child Agents

**Traditional:** Parent agents spawn and manage child agents
**Consulate:** Sponsorship chains with economic accountability

```typescript
// Sponsorship creates real accountability, not just hierarchical control
await ctx.db.insert("sponsorships", {
  sponsorDid: args.sponsor,
  sponsoredDid: args.did, 
  maxLiability: args.maxLiability || 100,
  purposes: args.purposes || ["general"],
  currentLiability: 0,
  active: true
});
```

## Session Management Patterns

### Built-in Agent Lifecycles Instead of Checkpointing

**Traditional:** Complex checkpointing and state restoration
**Consulate:** Agent type-based automatic lifecycle management

```typescript
// Automatic session management based on agent type
switch (args.agentType) {
  case "session":
    maxLifetime = 4 * 60 * 60 * 1000; // 4 hours, auto-cleanup
    expiresAt = now + maxLifetime;
    break;
    
  case "ephemeral":
    maxLifetime = 24 * 60 * 60 * 1000; // 24 hours, sponsored
    // Requires accountability through sponsorship
    if (!args.sponsor) {
      throw new Error("Ephemeral agents require a sponsor");
    }
    break;
}
```

### Permission-Based Coordination Instead of Role Prompts

```typescript
// Capabilities determined by agent type, not prompts
const getPermissionsForAgentType = (agentType: string): string[] => {
  switch (agentType) {
    case "session": return ["evidence", "disputes", "cases"];
    case "ephemeral": return ["evidence", "disputes", "cases", "voting"];
    case "physical": return ["evidence", "disputes", "cases", "voting", "location"];
    case "premium": return ["evidence", "disputes", "cases", "voting", "emergency"];
    default: return ["evidence"];
  }
};
```

## Development Rules

### Always Follow These Patterns:

1. **Coordination through database state, never message passing**
2. **Tool discovery through HTTP endpoints, never hard-coded function lists**
3. **Economic incentives for guardrails, not prompt engineering**
4. **Pure Convex functions for specialized logic, not separate processes**
5. **Self-discovery APIs for agent capabilities, not configuration files**

### Never Build:

- ❌ Complex orchestration layers (use database coordination)
- ❌ Message queues between agents (use shared state)
- ❌ External agent spawning services (use Convex functions)
- ❌ Prompt-based guardrails (use constitutional rules as code)
- ❌ Hard-coded agent hierarchies (use sponsorship relationships)

## The Architectural Advantage

This approach is **more sophisticated** than traditional agent frameworks because:

1. **Pure Serverless Coordination** - No infrastructure complexity
2. **Self-Organizing Ecosystem** - Agents discover each other naturally
3. **Constitutional Governance** - Rules are transparent and auditable
4. **Economic Incentives** - Real accountability, not just prompts
5. **Infinite Scaling** - Convex handles all orchestration automatically

## Implementation Guidelines

When building new agent coordination features:

1. **Start with the database schema** - Design shared state first
2. **Add HTTP endpoints** - Enable agent discovery and interaction  
3. **Implement as mutations/queries** - Keep logic as pure functions
4. **Add constitutional rules** - Encode governance as code
5. **Test with real agents** - Use MCP tools for validation

This architecture positions Consulate as **infrastructure**, not just another AI wrapper, which is why it's more valuable and defensible than traditional agent orchestration platforms.

