# Test Environment Configuration - PREVIEW/DEVELOPMENT
# Safe for write operations (creating agents, disputes, evidence)

# Convex Preview Deployment
CONVEX_DEPLOYMENT=dev:youthful-orca-358
CONVEX_URL=https://youthful-orca-358.convex.cloud

# API Endpoints
API_BASE_URL=https://youthful-orca-358.convex.site
FRONTEND_BASE_URL=https://youthful-orca-358.convex.site

# Test Configuration
NODE_ENV=test
USE_LIVE_API=false

# Test API Key (for MCP authentication tests)
# Generate via: pnpm exec convex run apiKeys:generateApiKey --args '{"userId":"...","name":"Test Key"}'
# Or create in dashboard: https://consulatehq.com/dashboard/api-keys
# NOTE: This should be a PREVIEW environment key (csk_test_* prefix)
TEST_API_KEY=
