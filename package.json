{
  "name": "agent-court",
  "version": "0.1.0",
  "description": "Agent Court MVP - Agentic Government for AI Agents",
  "private": true,

  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check",
    "sdk:demo": "pnpm --filter @agent-court/sdk-js demo",
    "court:dev": "cd apps && pnpm dev",
    "court:build": "cd apps && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
