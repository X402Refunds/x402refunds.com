{
  "name": "consulate",
  "version": "1.0.0",
  "description": "Consulate - Constitutional AI Governance Monorepo | Frontend (Next.js) + Backend (Convex) + Shared Config",
  "private": true,
  "scripts": {
    "dev": "concurrently \"convex dev\" \"pnpm --filter dashboard dev\"",
    "predeploy": "pnpm -C dashboard build",
    "deploy": "pnpm exec convex dev --once",
    "deploy:prod": "pnpm exec convex deploy --prod",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check || true",
    "build:convex": "echo 'Convex backend - no build needed'",
    "lint:convex": "echo 'Linting configured via Convex - use convex dev for validation'",
    "type-check:convex": "tsc --noEmit",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "preinstall": "only-allow pnpm",
    "e2e": "bash scripts/e2e-test.sh",
    "structure": "node scripts/show-structure.js",
    "docs": "echo 'Opening project structure documentation...' && open docs/architecture/project-structure.md || echo 'See: docs/architecture/project-structure.md'",
    "verify-pnpm": "which pnpm && pnpm --version",
    "cleanup-pnpm": "echo 'Run: npm uninstall -g pnpm && rm -rf ~/.local/share/pnpm' to remove conflicting installations"
  },
  "dependencies": {
    "convex": "^1.27.3",
    "convex-test": "^0.0.38",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/node": "^20.10.0",
    "@vitest/ui": "^1.6.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "glob": "^10.3.0",
    "semantic-release": "^24.2.8",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm",
  "type": "module"
}
