{
  "name": "consulate",
  "version": "1.0.0",
  "description": "Consulate - Agent Dispute Resolution | Frontend (Vercel) + Backend (Convex) + Shared Config",
  "private": true,
  "scripts": {
    "deploy": "pnpm exec convex deploy -y",
    "check-logs": "pnpm convex logs --prod",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check || true",
    "type-check:convex": "tsc --noEmit",
    "dev": "pnpm --filter dashboard dev",
    "test": "vitest",
    "test:run": "vitest run",
    "postinstall": "node scripts/install-hooks.js",
    "update-context": "node scripts/generate-context-graph.js",
    "hash-rules": "node scripts/hash-and-timestamp-rules.js",
    "version-rules": "node scripts/version-rules.js"
  },
  "dependencies": {
    "convex": "^1.27.3",
    "convex-test": "^0.0.38",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.0.0",
    "semantic-release": "^24.2.8",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm",
  "type": "module"
}
