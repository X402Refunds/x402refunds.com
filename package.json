{
  "name": "consulate",
  "version": "1.0.0",
  "description": "Consulate - Agent Dispute Resolution | Frontend (Vercel) + Backend (Convex) + Shared Config",
  "private": true,
  "scripts": {
    "predeploy": "pnpm -C dashboard build",
    "deploy": "pnpm exec convex deploy -y",
    "deploy:frontend": "vercel deploy --prod --yes",
    "check-logs": "pnpm convex logs --prod",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check || true",
    "type-check:convex": "tsc --noEmit",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "postinstall": "node scripts/install-hooks.js",
    "update-context": "node scripts/generate-context-graph.js",
    "index-supabase": "node scripts/index-to-supabase.js",
    "e2e": "bash scripts/e2e-test.sh",
    "structure": "node scripts/show-structure.js",
    "docs": "echo 'Opening project structure documentation...' && open docs/architecture/project-structure.md || echo 'See: docs/architecture/project-structure.md'",
    "verify-pnpm": "which pnpm && pnpm --version",
    "cleanup-pnpm": "echo 'Run: npm uninstall -g pnpm && rm -rf ~/.local/share/pnpm' to remove conflicting installations",
    "demo:enterprise": "node scripts/demo-enterprise-sla.js",
    "demo:sla": "node scripts/demo-enterprise-sla.js",
    "demo:disputes": "./scripts/start-dispute-demo.sh",
    "demo:engine": "node scripts/ai-vendor-dispute-engine.js",
    "demo:monitor": "node scripts/dispute-monitor.js",
    "demo:status": "node scripts/dispute-monitor.js health"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "convex": "^1.27.3",
    "convex-test": "^0.0.38",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/node": "^20.10.0",
    "@vitest/ui": "^1.6.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "glob": "^10.3.0",
    "semantic-release": "^24.2.8",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm",
  "type": "module"
}
