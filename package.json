{
  "name": "x402-disputes",
  "version": "1.0.0",
  "description": "x402disputes.com - Permissionless dispute filing and resolution for X-402 payments | On-chain reputation system | Oracle network verification | Ethereum smart contracts + Convex backend + Next.js dashboard",
  "private": true,
  "scripts": {
    "deploy": "pnpm exec convex deploy --yes",
    "deploy:dev": "pnpm exec convex dev --once",
    "check-logs": "pnpm convex logs",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check || true",
    "type-check:convex": "tsc --noEmit",
    "dev": "pnpm --filter dashboard dev",
    "test": "vitest",
    "test:run": "bash scripts/test-preview.sh",
    "test:api": "vitest run test/api.test.ts",
    "test:unit": "vitest run test/agents.test.ts test/cases.test.ts",
    "test:preview": "bash scripts/test-preview.sh",
    "test:production": "bash scripts/test-production.sh",
    "test:smoke": "bash scripts/test-preview.sh",
    "test:smoke:prod": "bash scripts/test-production.sh",
    "postinstall": "node scripts/install-hooks.js",
    "update-context": "node scripts/generate-context-graph.js",
    "hash-rules": "node scripts/hash-and-timestamp-rules.js",
    "version-rules": "node scripts/version-rules.js"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.62",
    "@convex-dev/agent": "^0.2.12",
    "@convex-dev/workflow": "^0.2.7",
    "@convex-dev/workpool": "^0.2.19",
    "ai": "^5.0.87",
    "convex": "^1.28.2",
    "convex-test": "^0.0.38",
    "viem": "~2.38.6",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "1.6.1",
    "eslint": "^9.0.0",
    "semantic-release": "^24.2.8",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm",
  "type": "module"
}
