# Convex Deployment
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Application URLs (configurable per environment)
NEXT_PUBLIC_APP_URL=https://x402disputes.com
NEXT_PUBLIC_API_URL=https://api.x402disputes.com

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Blockchain Explorer API Keys (for transaction verification)
# Etherscan V2 API supports both Ethereum (chainid=1) and Base (chainid=8453)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY= # Optional - will fall back to ETHERSCAN_API_KEY
