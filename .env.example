# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Object Storage (choose one)
STORAGE_DRIVER=r2  # or 'b2'

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=agent-court-evidence
R2_ENDPOINT=

# Backblaze B2 (alternative)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=agent-court-evidence
B2_ENDPOINT=

# Transparency
REKOR_URL=http://localhost:3000  # or https://rekor.sigstore.dev
REKOR_TREE_ID=

# Court Engine - now integrated into Convex (no separate server needed)

# Agent Keys (for demo)
DEMO_AGENT_1_PRIVATE_KEY=
DEMO_AGENT_2_PRIVATE_KEY=
DEMO_JUDGE_PRIVATE_KEY=

# Development
NODE_ENV=development
LOG_LEVEL=info
