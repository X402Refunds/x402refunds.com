# Convex Configuration (for codebase RAG - Phase 2)
# Copy this file to .env.local and fill in your values

# Convex Deployment URL
# Get from: https://dashboard.convex.dev/deployment/settings
# Format: https://your-deployment.convex.cloud
CONVEX_URL=https://your-deployment.convex.cloud

# Embedding Provider (choose ONE)
# -----------------------------------

# Option 1: OpenRouter (RECOMMENDED - most flexible, supports many models)
# Get from: https://openrouter.ai/keys
# Supports: OpenAI, Anthropic, Mistral, and many more through one API
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Option 2: OpenAI Direct (if you prefer OpenAI directly)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Option 3: Anthropic (note: doesn't support embeddings yet, use OpenRouter)
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
